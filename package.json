{
  "name": "influencer-discovery-engine",
  "version": "0.3.0",
  "description": "Influencer Discovery Engine - Full Stack Application",
  "private": true,
  "scripts": {
    "build": "cd frontend && npm run build",
    "dev": "concurrently \"cd frontend && npm run dev\" \"python -m uvicorn app:app --reload --host 0.0.0.0 --port 8000\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "python -m uvicorn app:app --reload --host 0.0.0.0 --port 8000",
    "start": "cd frontend && npm run start",
    "lint": "cd frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "swr": "^2.4.1"
  }
}
